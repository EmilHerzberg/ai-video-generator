{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "render-post.schema.json",
  "title": "RenderPost",
  "description": "Path A render contract — content the fixed PostRenderer turns into pixels. The visualization is a discriminated union on `kind`; each branch carries only its own fields. Chart values are 0..1 fractions. (This lean form is generated as-is for Anthropic/DeepSeek; tools/lib/render-schema.mjs derives an OpenAI-strict variant.)",
  "type": "object",
  "required": ["id", "headline", "visualization"],
  "properties": {
    "id": { "type": "string" },
    "eyebrow": { "type": "string", "maxLength": 40 },
    "headline": { "type": "string", "maxLength": 120 },
    "visualization": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "series"],
          "properties": {
            "kind": { "type": "string", "enum": ["chart"] },
            "caption": { "type": "string", "maxLength": 60 },
            "series": {
              "type": "array",
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": ["label", "values", "color"],
                "properties": {
                  "label": { "type": "string" },
                  "values": { "type": "array", "items": { "type": "number" }, "minItems": 2 },
                  "color": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
                  "endValueLabel": { "type": "string" }
                }
              }
            },
            "xLabels": { "type": "array", "items": { "type": "string" } },
            "yMax": { "type": "number" },
            "yMin": { "type": "number" },
            "variant": { "type": "string", "enum": ["line", "area", "stepped"] },
            "markers": { "type": "string", "enum": ["off", "on"] },
            "annotations": {
              "type": "array",
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": ["x", "label"],
                "properties": {
                  "seriesIndex": { "type": "number" },
                  "x": { "type": ["number", "string"] },
                  "label": { "type": "string", "maxLength": 18 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "left", "right"],
          "properties": {
            "kind": { "type": "string", "enum": ["comparison"] },
            "caption": { "type": "string", "maxLength": 60 },
            "revealMode": { "type": "string", "enum": ["paired", "sequential", "sequentialCentered"] },
            "left": { "$ref": "#/$defs/col" },
            "right": { "$ref": "#/$defs/col" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "big"],
          "properties": {
            "kind": { "type": "string", "enum": ["stat"] },
            "caption": { "type": "string", "maxLength": 60 },
            "big": { "type": "string", "maxLength": 40 },
            "sub": { "type": "string", "maxLength": 80 },
            "note": { "type": "string", "maxLength": 40 },
            "proportion": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "0..1 fraction when big expresses a proportion of a whole — draws a ring that sweeps to it"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "entries"],
          "properties": {
            "kind": { "type": "string", "enum": ["claims"] },
            "caption": { "type": "string", "maxLength": 60 },
            "revealMode": { "type": "string", "enum": ["stagger", "spotlight"] },
            "entries": {
              "type": "array",
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": ["date", "source", "claim", "reality"],
                "properties": {
                  "date": { "type": "string", "maxLength": 16 },
                  "source": { "type": "string", "maxLength": 28 },
                  "claim": { "type": "string", "maxLength": 90 },
                  "reality": { "type": "string", "maxLength": 60 },
                  "note": { "type": "string", "maxLength": 24 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "nodes", "perStepLabel", "endLabel"],
          "properties": {
            "kind": { "type": "string", "enum": ["pipeline"] },
            "caption": { "type": "string", "maxLength": 60 },
            "nodes": {
              "type": "array",
              "maxItems": 8,
              "items": {
                "type": "object",
                "required": ["step", "cumulative"],
                "properties": {
                  "step": { "type": "integer" },
                  "cumulative": { "type": "string", "maxLength": 8 }
                }
              }
            },
            "perStepLabel": { "type": "string", "maxLength": 40 },
            "endLabel": { "type": "string", "maxLength": 10 },
            "endAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "segments"],
          "properties": {
            "kind": { "type": "string", "enum": ["stack"] },
            "caption": { "type": "string", "maxLength": 60 },
            "segments": {
              "type": "array",
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["width", "color"],
                "properties": {
                  "width": { "type": "number" },
                  "color": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
                  "label": { "type": "string", "maxLength": 16 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "topGroupLabel", "bottomGroupLabel", "topEntries", "bottomEntries", "topAccent", "bottomAccent", "minYear", "maxYear"],
          "properties": {
            "kind": { "type": "string", "enum": ["ranges"] },
            "caption": { "type": "string", "maxLength": 60 },
            "topGroupLabel": { "type": "string", "maxLength": 26 },
            "bottomGroupLabel": { "type": "string", "maxLength": 26 },
            "topEntries": { "type": "array", "maxItems": 4, "items": { "$ref": "#/$defs/rangeEntry" } },
            "bottomEntries": { "type": "array", "maxItems": 4, "items": { "$ref": "#/$defs/rangeEntry" } },
            "topAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "bottomAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "minYear": { "type": "integer" },
            "maxYear": { "type": "integer" },
            "marketLine": {
              "type": "object",
              "required": ["year", "label"],
              "properties": {
                "year": { "type": "integer" },
                "label": { "type": "string", "maxLength": 24 }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "rowHeaders", "colHeaders", "tl", "tr", "bl", "br"],
          "properties": {
            "kind": { "type": "string", "enum": ["matrix"] },
            "caption": { "type": "string", "maxLength": 60 },
            "rowHeaders": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string", "maxLength": 18 } },
            "colHeaders": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string", "maxLength": 18 } },
            "rowAccents": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] } },
            "tl": { "$ref": "#/$defs/matrixCell" },
            "tr": { "$ref": "#/$defs/matrixCell" },
            "bl": { "$ref": "#/$defs/matrixCell" },
            "br": { "$ref": "#/$defs/matrixCell" },
            "highlightCell": { "type": "string", "enum": ["tl", "tr", "bl", "br"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "items"],
          "properties": {
            "kind": { "type": "string", "enum": ["divergence"] },
            "caption": { "type": "string", "maxLength": 60 },
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["label", "start", "end"],
                "properties": {
                  "label": { "type": "string", "maxLength": 24 },
                  "start": { "type": "number" },
                  "end": { "type": "number" },
                  "startText": { "type": "string", "maxLength": 12 },
                  "endText": { "type": "string", "maxLength": 12 }
                }
              }
            },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "startAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "endAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "startLabel": { "type": "string", "maxLength": 16 },
            "endLabel": { "type": "string", "maxLength": 16 },
            "mode": { "type": "string", "enum": ["dumbbell", "slope"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "tiers"],
          "properties": {
            "kind": { "type": "string", "enum": ["tiers"] },
            "caption": { "type": "string", "maxLength": 60 },
            "tiers": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": ["label", "items"],
                "properties": {
                  "label": { "type": "string", "maxLength": 18 },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
                  "items": {
                    "type": "array",
                    "maxItems": 5,
                    "items": {
                      "type": "object",
                      "required": ["label"],
                      "properties": {
                        "label": { "type": "string", "maxLength": 14 },
                        "note": { "type": "string", "maxLength": 20 }
                      }
                    }
                  }
                }
              }
            },
            "mode": { "type": "string", "enum": ["tiers", "ranked"] },
            "showValue": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "categories"],
          "properties": {
            "kind": { "type": "string", "enum": ["bar"] },
            "caption": { "type": "string", "maxLength": 60 },
            "categories": {
              "type": "array",
              "minItems": 1,
              "maxItems": 10,
              "items": {
                "type": "object",
                "required": ["label"],
                "properties": {
                  "label": { "type": "string", "maxLength": 18 },
                  "value": { "type": "number" },
                  "values": { "type": "array", "items": { "type": "number" }, "maxItems": 5 },
                  "valueText": { "type": "string", "maxLength": 8 },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
                }
              }
            },
            "mode": { "type": "string", "enum": ["simple", "grouped", "stacked"] },
            "orientation": { "type": "string", "enum": ["vertical", "horizontal"] },
            "valueLabels": { "type": "string", "enum": ["auto", "off"] },
            "sort": { "type": "string", "enum": ["none", "desc", "asc"] },
            "seriesLabels": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 14 } },
            "seriesAccents": { "type": "array", "maxItems": 5, "items": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] } },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "unit": { "type": "string", "maxLength": 6 },
            "referenceLine": {
              "type": "object",
              "required": ["value"],
              "properties": {
                "value": { "type": "number" },
                "label": { "type": "string", "maxLength": 18 }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "points"],
          "properties": {
            "kind": { "type": "string", "enum": ["scatter"] },
            "caption": { "type": "string", "maxLength": 60 },
            "points": {
              "type": "array",
              "minItems": 2,
              "maxItems": 20,
              "items": {
                "type": "object",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "label": { "type": "string", "maxLength": 20 },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
                }
              }
            },
            "xLabel": { "type": "string", "maxLength": 24 },
            "yLabel": { "type": "string", "maxLength": 24 },
            "xMin": { "type": "number" },
            "xMax": { "type": "number" },
            "yMin": { "type": "number" },
            "yMax": { "type": "number" },
            "xUnit": { "type": "string", "maxLength": 6 },
            "yUnit": { "type": "string", "maxLength": 6 },
            "trendLine": { "type": "string", "enum": ["off", "fit"] },
            "quadrants": { "type": "string", "enum": ["off", "on"] },
            "xDivider": { "type": "number" },
            "yDivider": { "type": "number" },
            "quadrantLabels": { "type": "array", "maxItems": 4, "items": { "type": "string", "maxLength": 16 } },
            "pointLabels": { "type": "string", "enum": ["auto", "off"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "segments"],
          "properties": {
            "kind": { "type": "string", "enum": ["donut"] },
            "caption": { "type": "string", "maxLength": 60 },
            "segments": {
              "type": "array",
              "minItems": 1,
              "maxItems": 6,
              "items": {
                "type": "object",
                "required": ["label", "value"],
                "properties": {
                  "label": { "type": "string", "maxLength": 14 },
                  "value": { "type": "number" },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
                }
              }
            },
            "centerLabel": { "type": "string", "maxLength": 16 },
            "centerValue": { "type": "string", "maxLength": 6 },
            "valueLabels": { "type": "string", "enum": ["auto", "off"] },
            "centerTotal": { "type": "string", "enum": ["on", "off"] },
            "unit": { "type": "string", "maxLength": 6 },
            "emphasis": { "type": "integer", "minimum": 0, "maximum": 5 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "series"],
          "properties": {
            "kind": { "type": "string", "enum": ["area"] },
            "caption": { "type": "string", "maxLength": 60 },
            "series": {
              "type": "array",
              "minItems": 1,
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": ["values"],
                "properties": {
                  "label": { "type": "string", "maxLength": 18 },
                  "values": { "type": "array", "minItems": 2, "maxItems": 24, "items": { "type": "number" } },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
                  "endValueLabel": { "type": "string", "maxLength": 8 }
                }
              }
            },
            "xLabels": { "type": "array", "maxItems": 24, "items": { "type": "string", "maxLength": 8 } },
            "mode": { "type": "string", "enum": ["simple", "stacked"] },
            "valueLabels": { "type": "string", "enum": ["auto", "off"] },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "unit": { "type": "string", "maxLength": 6 },
            "annotations": {
              "type": "array",
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": ["x", "label"],
                "properties": {
                  "seriesIndex": { "type": "number" },
                  "x": { "type": ["number", "string"] },
                  "label": { "type": "string", "maxLength": 18 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "enum": ["histogram"] },
            "caption": { "type": "string", "maxLength": 60 },
            "values": { "type": "array", "maxItems": 400, "items": { "type": "number" } },
            "bins": {
              "type": "array",
              "maxItems": 14,
              "items": {
                "type": "object",
                "required": ["x0", "x1", "count"],
                "properties": {
                  "x0": { "type": "number" },
                  "x1": { "type": "number" },
                  "count": { "type": "number" }
                }
              }
            },
            "binCount": { "type": "integer" },
            "xLabel": { "type": "string", "maxLength": 24 },
            "yLabel": { "type": "string", "maxLength": 24 },
            "xUnit": { "type": "string", "maxLength": 6 },
            "markers": { "type": "string", "enum": ["off", "median", "mean", "medianMean", "p95"] },
            "markerLines": {
              "type": "array",
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": ["value"],
                "properties": {
                  "value": { "type": "number" },
                  "label": { "type": "string", "maxLength": 16 }
                }
              }
            },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "valueLabels": { "type": "string", "enum": ["auto", "off"] },
            "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "stages"],
          "properties": {
            "kind": { "type": "string", "enum": ["funnel"] },
            "caption": { "type": "string", "maxLength": 60 },
            "stages": {
              "type": "array",
              "minItems": 2,
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["label", "value"],
                "properties": {
                  "label": { "type": "string", "maxLength": 22 },
                  "value": { "type": "number" },
                  "valueText": { "type": "string", "maxLength": 10 },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
                }
              }
            },
            "mode": { "type": "string", "enum": ["funnel", "bars"] },
            "unit": { "type": "string", "maxLength": 6 },
            "dropLabels": { "type": "string", "enum": ["auto", "off"] },
            "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "candles"],
          "properties": {
            "kind": { "type": "string", "enum": ["candlestick"] },
            "caption": { "type": "string", "maxLength": 60 },
            "candles": {
              "type": "array",
              "minItems": 2,
              "maxItems": 14,
              "items": {
                "type": "object",
                "required": ["open", "high", "low", "close"],
                "properties": {
                  "label": { "type": "string", "maxLength": 10 },
                  "open": { "type": "number" },
                  "high": { "type": "number" },
                  "low": { "type": "number" },
                  "close": { "type": "number" }
                }
              }
            },
            "mode": { "type": "string", "enum": ["candles", "ohlc"] },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "upAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "downAccent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "unit": { "type": "string", "maxLength": 6 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "groups"],
          "properties": {
            "kind": { "type": "string", "enum": ["distribution"] },
            "caption": { "type": "string", "maxLength": 60 },
            "groups": {
              "type": "array",
              "minItems": 1,
              "maxItems": 5,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string", "maxLength": 14 },
                  "values": { "type": "array", "maxItems": 200, "items": { "type": "number" } },
                  "min": { "type": "number" },
                  "q1": { "type": "number" },
                  "median": { "type": "number" },
                  "q3": { "type": "number" },
                  "max": { "type": "number" },
                  "mean": { "type": "number" },
                  "outliers": { "type": "array", "maxItems": 8, "items": { "type": "number" } }
                }
              }
            },
            "mode": { "type": "string", "enum": ["box", "rangeMarkers"] },
            "axisMin": { "type": "number" },
            "axisMax": { "type": "number" },
            "showMean": { "type": "string", "enum": ["off", "on"] },
            "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
            "groupAccents": { "type": "array", "maxItems": 5, "items": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] } },
            "unit": { "type": "string", "maxLength": 6 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "categories"],
          "properties": {
            "kind": { "type": "string", "enum": ["taxonomy"] },
            "caption": { "type": "string", "maxLength": 60 },
            "categories": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["label"],
                "properties": {
                  "label": { "type": "string", "maxLength": 16 },
                  "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
                  "children": {
                    "type": "array",
                    "maxItems": 6,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["label"],
                      "properties": {
                        "label": { "type": "string", "maxLength": 14 },
                        "value": { "type": "number" }
                      }
                    }
                  }
                }
              }
            },
            "rootLabel": { "type": "string", "maxLength": 18 },
            "mode": { "type": "string", "enum": ["curve", "elbow"] },
            "showValues": { "type": "string", "enum": ["off", "on"] },
            "unit": { "type": "string", "maxLength": 6 }
          }
        }
      ]
    },
    "metrics": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string", "maxLength": 24 },
          "value": { "type": "string", "maxLength": 16 },
          "delta": { "type": "string", "maxLength": 20 },
          "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
          "deltaTrend": { "type": "string", "enum": ["up", "down", "flat"] }
        }
      }
    },
    "takeaway": { "type": "string", "maxLength": 140 },
    "signal": { "type": "string", "maxLength": 40 }
  },
  "$defs": {
    "col": {
      "type": "object",
      "required": ["title", "tone", "items"],
      "properties": {
        "title": { "type": "string", "maxLength": 32 },
        "tone": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] },
        "items": { "type": "array", "maxItems": 4, "items": { "type": "string", "maxLength": 70 } }
      }
    },
    "rangeEntry": {
      "type": "object",
      "required": ["label", "start", "end"],
      "properties": {
        "label": { "type": "string", "maxLength": 26 },
        "start": { "type": "integer" },
        "end": { "type": "integer" },
        "openEnd": { "type": "boolean" }
      }
    },
    "matrixCell": {
      "type": "object",
      "required": ["value", "accent"],
      "properties": {
        "value": { "type": "string", "maxLength": 12 },
        "delta": { "type": "string", "maxLength": 20 },
        "accent": { "type": "string", "enum": ["cyan", "amber", "violet", "mint", "burnt"] }
      }
    }
  }
}
